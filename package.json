{
  "name": "my-frontend-engineer-challenge",
  "version": "0.0.0",
  "backendVersion": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prod:react": "vite preview",
    "dev:react": "vite --port 3000",
    "build:react": "vite build",
    "test:unit": "vitest --coverage --silent --config .config/tests/vitest.config.ts",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "e2e:install": "playwright install chromium",
    "api:download": "curl -o src/shared/__api__/generator/openapi.yml https://gitlab.webant.ru/api/v4/projects/1703/packages/generic/openapi/${swaggerVersion}/openapi.yml",
    "api:clean": "rm -rf src/shared/__api__/__resources__ src/shared/__api__/__schemas__ src/shared/__api__/__types__ src/shared/__api__/__mocks__",
    "api:format": "prettier --write \"src/shared/__api__/**/*.{js,jsx,ts,tsx,json,scss}\" --config .config/prettier/prettier.config.cjs --ignore-path .config/prettier/.prettierignore",
    "api:generate": "pnpm api:clean && kubb generate --config ./src/shared/__api__/generator/generator.config.ts",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,scss}\" --config .config/prettier/prettier.config.cjs --ignore-path .config/prettier/.prettierignore --ignore-pattern \"src/shared/__api__/**\"",
    "oxlint": "oxlint --config .config/oxlint/.oxlintrc.config.json"
  },
  "dependencies": {
    "@heroui/react": "^2.8.0",
    "@heroui/theme": "2.4.18",
    "@hookform/resolvers": "^5.1.1",
    "@internationalized/date": "^3.10.1",
    "@reatom/core": "^1000.15.2",
    "@reatom/react": "^1000.2.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.10.0",
    "axios-retry": "^4.5.0",
    "change-case": "^5.4.4",
    "framer-motion": "^12.38.0",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.562.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.58.1",
    "react-i18next": "^15.5.3",
    "react-intl": "^7.1.11",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@kubb/cli": "4.37.1",
    "@kubb/core": "4.37.1",
    "@kubb/plugin-client": "4.37.1",
    "@kubb/plugin-msw": "4.37.1",
    "@kubb/plugin-oas": "4.37.1",
    "@kubb/plugin-ts": "4.37.1",
    "@kubb/plugin-zod": "4.37.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^24.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.0.0",
    "mockjs": "^1.1.0",
    "msw": "^2.10.2",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "prettier": "3.6.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2",
    "web-vitals": "^4.2.4"
  },
  "overrides": {
    "rollup": "4.20.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.20.0"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
